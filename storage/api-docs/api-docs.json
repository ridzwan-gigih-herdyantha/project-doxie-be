            "post": {
                "tags": [
                    "Messages"
                ],
                "summary": "Send a question and stream the AI answer (SSE)",
                "description": "Returns a text/event-stream. Each event is `data: {\"content\": \"...\"}` and the stream ends with `data: [DONE]`.",
                "operationId": "1a2b56159f32ca6d4e35337d2c92ae07",
                "parameters": [
                    {
                        "name": "chatSession",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "question",
                                    "model"
                                ],
                                "properties": {
                                    "question": {
                                        "type": "string",
                                        "example": "What is this document about?"
                                    },
                                    "model": {
                                        "type": "string",
                                        "example": "gpt-4o",
                                        "enum": [
                                            "gpt-4o",
                                            "claude-3-5-sonnet-20241022",
                                            "gemini-2.5-flash"
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Server-sent events stream of the answer",
                        "content": {
                            "text/event-stream": {
                                "schema": {
                                    "type": "string",
                                    "example": "data: {\"content\": \"This document \"}\\n\\ndata: {\"content\": \"is the 2025 \"}\\n\\ndata: {\"content\": \"annual report.\"}\\n\\ndata: [DONE]\\n\\n"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "User": {
                "properties": {
                    "uuid": {
                        "type": "string",
                        "format": "uuid",
                        "example": "9b1deb4d-3b7d-4bad-9bdd-2b0d7b3dcb6d"
                    },
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "admin@doxie.ai"
                    },
                    "avatar_url": {
                        "description": "Auto-generated initial avatar as a base64-encoded SVG data URI",
                        "type": "string",
                        "example": "data:image/svg+xml;base64,PHN2ZyB4bWxucz0i..."
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-06-17T08:30:00.000000Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-06-17T08:30:00.000000Z"
                    }
                },
                "type": "object"
            },
            "Document": {
                "properties": {
                    "uuid": {
                        "type": "string",
                        "format": "uuid",
                        "example": "9b1deb4d-3b7d-4bad-9bdd-2b0d7b3dcb6d"
                    },
                    "title": {
                        "type": "string",
                        "example": "Annual Report 2025"
                    },
                    "file_name": {
                        "type": "string",
                        "example": "annual-report-2025.pdf"
                    },
                    "file_path": {
                        "type": "string",
                        "example": "documents/1/annual-report-2025.pdf"
                    },
                    "file_size": {
                        "type": "integer",
                        "example": 482133
                    },
                    "status": {
                        "type": "string",
                        "example": "ready",
                        "enum": [
                            "processing",
                            "ready",
                            "failed"
                        ]
                    },
                    "page_count": {
                        "type": "integer",
                        "example": 12
                    },
                    "file_url": {
                        "type": "string",
                        "example": "https://r2.example.com/documents/1/annual-report-2025.pdf?signature=...",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-06-17T08:30:00.000000Z"
                    },
                    "updated_at": {
